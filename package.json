{
  "name": "openforge-mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Free, open-source MCP server for Unity and Blender AI control",
  "license": "MIT",
  "scripts": {
    "build": "cd packages/mcp-server && npm run build",
    "test": "cd packages/mcp-server && npx vitest run",
    "test:python": "cd packages/blender-addon/tests && python -m pytest -v",
    "test:all": "npm run test && npm run test:python",
    "setup": "cd packages/mcp-server && node dist/cli/index.js setup",
    "start": "cd packages/mcp-server && node dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
